# LiteLLM Gateway (required)
LITELLM_API_KEY=your_litellm_api_key

# LiteLLM Gateway URL (optional, default: http://localhost:4000)
# LITELLM_BASE_URL=http://localhost:4000
# LITELLM_EMBEDDING_MODEL=

# Strands agent URL (optional, default: http://localhost:8080)
# STRANDS_URL=http://localhost:8080

# Strands agent callback URL into the Node app (optional, default: http://localhost:5173)
# NODE_API_BASE_URL=http://localhost:5173

# Strands session persistence (optional, defaults to DATABASE_URL)
# STRANDS_POSTGRES_DSN=postgresql://open_analyst:open_analyst_dev@localhost:5432/open_analyst

# Optional external Python virtualenv locations for local development.
# Keeping these outside the repo avoids React Router/Vite watcher exhaustion.
# OPEN_ANALYST_AGENT_VENV=$HOME/.venvs/open-analyst-strands-agent
# OPEN_ANALYST_ANALYST_MCP_VENV=$HOME/.venvs/open-analyst-analyst-mcp

# Artifact storage backend (optional, default: local)
# ARTIFACT_STORAGE_BACKEND=local

# Project workspace root (optional, default: ~/.config/open-analyst/workspaces)
# PROJECT_WORKSPACES_ROOT=/absolute/path/to/workspaces

# Local artifact directory override (optional)
# ARTIFACT_LOCAL_DIR=/absolute/path/to/artifacts

# Project-level storage settings can override these env defaults per project.
# Local artifacts resolve to <root>/<workspace-slug>/artifacts.
# S3 artifacts resolve to s3://<bucket>/<prefix>/<workspace-slug>/artifacts.

# S3 artifact storage settings (required when ARTIFACT_STORAGE_BACKEND=s3)
# ARTIFACT_S3_BUCKET=my-bucket
# ARTIFACT_S3_REGION=us-east-1
# ARTIFACT_S3_PREFIX=open-analyst-artifacts
# ARTIFACT_S3_ENDPOINT=

# PostgreSQL (required, start with: docker compose up -d)
DATABASE_URL=postgresql://open_analyst:open_analyst_dev@localhost:5432/open_analyst

# For AWS RDS in development, Node's pg client can use:
# DATABASE_URL=postgresql://user:pass@host:5432/open_analyst?sslmode=no-verify
# STRANDS_POSTGRES_DSN can use the same DSN and the Strands agent will normalize sslmode=no-verify for psycopg.

# Analyst MCP (optional unless you run services/analyst-mcp)
ANALYST_MCP_API_KEY=change-me
# ANALYST_MCP_POSTGRES_DSN=postgresql://open_analyst:open_analyst_dev@localhost:5432/open_analyst
# ANALYST_MCP_HOST=0.0.0.0
# ANALYST_MCP_PORT=8000
# ANALYST_MCP_CONTACT_EMAIL=research@example.com
# ANALYST_MCP_TIMEZONE=UTC
# If ANALYST_MCP_POSTGRES_DSN is omitted, analyst_mcp falls back to DATABASE_URL.
# analyst_mcp stores its own Postgres tables in schema "analyst_mcp".

# Analyst MCP optional provider-side LiteLLM config
# ANALYST_MCP_LITELLM_BASE_URL=http://localhost:4000
# ANALYST_MCP_LITELLM_API_KEY=
# ANALYST_MCP_LITELLM_CHAT_MODEL=
# ANALYST_MCP_LITELLM_EMBEDDING_MODEL=

# Optional Analyst MCP storage overrides
# ANALYST_MCP_DATA_DIR=services/analyst-mcp/data
# ANALYST_MCP_STORAGE_ROOT=services/analyst-mcp/data/articles
# ANALYST_MCP_INDEX_ROOT=services/analyst-mcp/data/indexes
# ANALYST_MCP_RAW_ROOT=services/analyst-mcp/data/raw
