# ============================================================
# Open Analyst — Environment Configuration
# Copy this file to .env and fill in required values.
# This is the single source of truth for both local dev
# (pnpm dev:all) and docker compose (docker compose up).
# ============================================================

# --- LLM Gateway (required) ---

LITELLM_API_KEY=your_litellm_api_key

# LiteLLM Gateway URL (optional, default: http://localhost:4000)
# LITELLM_BASE_URL=http://localhost:4000

# Embedding model for document retrieval (optional)
# LITELLM_EMBEDDING_MODEL=

# Chat model (optional, default: gpt-4.1-mini)
# LITELLM_CHAT_MODEL=gpt-4.1-mini
# LITELLM_FALLBACK_CHAT_MODELS=gpt-4.1,gpt-4.1-mini

# Tavily web search (optional, enables web_search and web_fetch agent tools)
# TAVILY_API_KEY=

# --- PostgreSQL (required) ---
# Start local database: docker compose up -d postgres
# The database name must match POSTGRES_DB in docker-compose.yml (open_analyst).

DATABASE_URL=postgresql://open_analyst:open_analyst_dev@localhost:5432/open_analyst

# For AWS RDS, Node's pg client can use:
# DATABASE_URL=postgresql://user:pass@host:5432/open_analyst?sslmode=no-verify
# analyst-mcp normalizes sslmode=no-verify for psycopg automatically.

# --- Service URLs (optional, defaults shown) ---

# LANGGRAPH_RUNTIME_URL=http://localhost:8081
# LANGGRAPH_RUNTIME_PUBLIC_URL=  # Browser-facing URL for runtime (defaults to LANGGRAPH_RUNTIME_URL)
# OPEN_ANALYST_WEB_URL=http://localhost:5173
# OPEN_ANALYST_WEB_PORT=5173

# --- Authentication (optional for local dev) ---

# AUTH_ENABLED=false
# SESSION_SECRET=change-me
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_PUBLIC_URL=http://localhost:8080
# KEYCLOAK_REALM=open-analyst
# KEYCLOAK_CLIENT_ID=open-analyst-web
# KEYCLOAK_CLIENT_SECRET=

# --- Analyst MCP ---

ANALYST_MCP_API_KEY=change-me
OPEN_ANALYST_INTERNAL_API_KEY=change-me

# Analyst MCP Postgres DSN (optional, falls back to DATABASE_URL)
# ANALYST_MCP_POSTGRES_DSN=postgresql://open_analyst:open_analyst_dev@localhost:5432/open_analyst

# ANALYST_MCP_HOST=0.0.0.0
# ANALYST_MCP_PORT=8000
# ANALYST_MCP_CONTACT_EMAIL=research@example.com
# ANALYST_MCP_TIMEZONE=UTC

# Optional Analyst MCP storage overrides (defaults are relative to cwd)
# ANALYST_MCP_DATA_DIR=data
# ANALYST_MCP_STORAGE_ROOT=data/articles

# Optional provider API keys
# ANALYST_MCP_SEMANTIC_SCHOLAR_API_KEY=
# ANALYST_MCP_OPENALEX_API_KEY=

# --- Artifact Storage ---

# Backend: "local" (default) or "s3"
# ARTIFACT_STORAGE_BACKEND=local

# Project workspace root (optional, default: ~/.config/open-analyst/workspaces)
# PROJECT_WORKSPACES_ROOT=/absolute/path/to/workspaces

# Local artifact directory (optional, default: ~/.config/open-analyst/captures)
# ARTIFACT_LOCAL_DIR=/absolute/path/to/captures

# S3 settings (required when ARTIFACT_STORAGE_BACKEND=s3)
# ARTIFACT_S3_BUCKET=my-bucket
# ARTIFACT_S3_REGION=us-east-1
# ARTIFACT_S3_PREFIX=open-analyst
# ARTIFACT_S3_ENDPOINT=

# --- Rate Limiting (optional, Bedrock users get automatic defaults) ---

# CHAT_RATE_LIMIT_RPS=0.75
# CHAT_RATE_LIMIT_MAX_BUCKET_SIZE=2
# CHAT_MAX_CONCURRENT_REQUESTS=2
# CHAT_RETRY_MAX_RETRIES=8
# CHAT_RETRY_INITIAL_DELAY_SECONDS=2.0
# CHAT_RETRY_BACKOFF_FACTOR=2.0

# --- Local Development ---

# External Python virtualenv locations (avoids Vite watcher exhaustion)
# OPEN_ANALYST_RUNTIME_VENV=$HOME/.venvs/open-analyst-langgraph-runtime
# OPEN_ANALYST_ANALYST_MCP_VENV=$HOME/.venvs/open-analyst-analyst-mcp
