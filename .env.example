# LiteLLM Gateway (required)
LITELLM_API_KEY=your_litellm_api_key

# LiteLLM Gateway URL (optional, default: http://localhost:4000)
# LITELLM_BASE_URL=http://localhost:4000

# Strands agent URL (optional, default: http://localhost:8080)
# STRANDS_URL=http://localhost:8080

# PostgreSQL (required, start with: docker compose up -d)
DATABASE_URL=postgresql://open_analyst:open_analyst_dev@localhost:5432/open_analyst
