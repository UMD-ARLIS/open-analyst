{
  "name": "open-analyst",
  "version": "2.0.0",
  "description": "Remote-first analyst application with headless agent runtime",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve build/server/index.js",
    "dev:legacy": "sh -c 'node scripts/headless-server.js & vite --host 0.0.0.0 --port 5173'",
    "serve:headless": "node scripts/headless-server.js",
    "dev:agent": "cd services/strands-agent && uv run python src/main.py",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:agent\"",
    "test:agent": "cd services/strands-agent && uv run pytest tests/ -v",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "@anthropic-ai/claude-code": "^2.1.42",
    "@anthropic-ai/sdk": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@react-router/dev": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@t3-oss/env-core": "^0.13.10",
    "@types/ws": "^8.18.1",
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "chokidar": "^4.0.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "glob": "^10.3.10",
    "isbot": "^5",
    "katex": "^0.16.27",
    "lucide-react": "^0.468.0",
    "ngrok": "^5.0.0-beta.2",
    "openai": "^6.22.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router": "^7.13.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^11.0.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/archiver": "^6.0.4",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.17"
  },
  "author": "Justin Mullins (ARLIS - Applied Research Laboratory for Intelligence and Security)",
  "license": "UNLICENSED",
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
