# Container-aware overrides for docker compose.
# Loaded AFTER .env — values here win for duplicate keys.
# These replace localhost references with container service names.

DATABASE_URL=postgresql://open_analyst:open_analyst_dev@postgres:5432/open_analyst
ANALYST_MCP_POSTGRES_DSN=postgresql://open_analyst:open_analyst_dev@postgres:5432/open_analyst
LANGGRAPH_RUNTIME_URL=http://runtime:8081
ANALYST_MCP_BASE_URL=http://analyst-mcp:8000
OPEN_ANALYST_WEB_URL=http://webapp:5173

# Runtime storage paths — must match volume mounts in docker-compose.yml
# Defaults resolve to ~/.config/open-analyst/{workspaces,captures} but
# appuser's home is /home/appuser inside the container.
PROJECT_WORKSPACES_ROOT=/home/appuser/.config/open-analyst/workspaces
ARTIFACT_LOCAL_DIR=/home/appuser/.config/open-analyst/captures

# Analyst MCP storage — must match volume mount and Dockerfile ENV
ANALYST_MCP_DATA_DIR=/var/open-analyst/analyst-mcp/data
ANALYST_MCP_STORAGE_ROOT=/var/open-analyst/analyst-mcp/data/articles
ANALYST_MCP_HOST=0.0.0.0
ANALYST_MCP_PORT=8000
