# Optional service-local override file.
# The repo-root .env is loaded automatically and should be the default place to configure these values.

# LiteLLM Gateway (required)
LITELLM_API_KEY=your_litellm_api_key

# LiteLLM Gateway URL (optional, default: http://localhost:4000)
# LITELLM_BASE_URL=http://localhost:4000

# Node.js API URL for callbacks (optional, default: http://localhost:5173)
# NODE_API_BASE_URL=http://localhost:5173
